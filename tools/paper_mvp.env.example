# Example values for project-root paper_mvp.env.
# paper_mvp.env is ignored by Git.

# openai / openai-compatible / gemini / anthropic
ENG_EASY_PROVIDER=openai

# For OpenAI-compatible providers:
ENG_EASY_API_KEY=
ENG_EASY_BASE_URL=https://api.openai.com/v1
ENG_EASY_MODEL=gpt-4o-mini

# For Gemini, use:
# ENG_EASY_PROVIDER=gemini
# ENG_EASY_API_KEY=
# ENG_EASY_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# ENG_EASY_MODEL=gemini-2.0-flash

# For Anthropic, use:
# ENG_EASY_PROVIDER=anthropic
# ENG_EASY_API_KEY=
# ENG_EASY_BASE_URL=https://api.anthropic.com
# ENG_EASY_MODEL=claude-sonnet-4-5

# Optional. If set, each sample runs primary config N-1 times and alt config once.
ENG_EASY_PROVIDER_ALT=
ENG_EASY_API_KEY_ALT=
ENG_EASY_BASE_URL_ALT=
ENG_EASY_MODEL_ALT=
